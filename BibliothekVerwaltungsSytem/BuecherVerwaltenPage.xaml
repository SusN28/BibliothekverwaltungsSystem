<Page x:Class="BibliothekVerwaltungsSytem.BuecherVerwaltenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BibliothekVerwaltungsSytem"
      mc:Ignorable="d"
      Title="BuecherVerwaltenPage">

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab-Navigation -->
        <Border Grid.Row="0" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="20,0">

                <Button Content="USER HINZUFUEGEN"
                        Width="200" Height="50" FontSize="14" FontWeight="SemiBold"
                        Background="#ECF0F1" Foreground="#7F8C8D"
                        BorderThickness="0" Margin="0,0,4,0" Cursor="Hand"
                        Click="BtnTabUserHinzufuegen_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="ALLE USER"
                        Width="200" Height="50" FontSize="14" FontWeight="SemiBold"
                        Background="#ECF0F1" Foreground="#7F8C8D"
                        BorderThickness="0" Margin="0,0,4,0" Cursor="Hand"
                        Click="BtnTabAlleUser_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="BUECHER VERWALTEN"
                        Width="200" Height="50" FontSize="14" FontWeight="Bold"
                        Background="#E74C3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnTabBuecher_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

       <!-- Suchbox + Buttons -->
<Grid Grid.Row="1" Margin="40,30,40,20">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="180"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="180"/>
    </Grid.ColumnDefinitions>

    <!-- Suchbox -->
    <Border Grid.Column="0"
            Background="White" BorderBrush="#E1E8ED" BorderThickness="0"
            CornerRadius="12" Margin="0,0,16,0" Padding="4">
        <Border.Effect>
            <DropShadowEffect Color="#E74C3C" Direction="270" ShadowDepth="0" BlurRadius="20" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <TextBox x:Name="SearchTextBox"
                     FontSize="16" FontFamily="Segoe UI" FontWeight="Medium"
                     Foreground="#2C3E50" Background="Transparent"
                     BorderThickness="0" Padding="20,18,60,18"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchTextBox_TextChanged"
                     CaretBrush="#E74C3C">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderThickness" Value="0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock Text="Suche nach Titel, Autor oder ISBN..."
                       FontSize="16" FontFamily="Segoe UI" FontWeight="Medium"
                       Foreground="#95A5A6" Padding="20,18,60,18"
                       VerticalAlignment="Center" IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsFocused, ElementName=SearchTextBox}" Value="False"/>
                                    <Condition Binding="{Binding Text.Length, ElementName=SearchTextBox}" Value="0"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Width="40" Height="40" Margin="0,0,12,0"
                    Background="#ECF0F1" CornerRadius="20">
                <TextBlock Text="&#128269;" FontSize="18" Foreground="#E74C3C"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>

    <!-- Buch hinzufuegen -->
    <Button Grid.Column="1"
            Content="+ Buch hinzufuegen"
            FontSize="13" FontWeight="Bold"
            Foreground="White" BorderThickness="0"
            Cursor="Hand" Click="BtnBuchHinzufuegen_Click">
        <Button.Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="#E74C3C"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#C0392B"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Button.Style>
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="10" Padding="0">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Button.Template>
    </Button>

    <!-- Autor hinzufuegen -->
    <Button Grid.Column="3"
            Content="+ Autor hinzufuegen"
            FontSize="13" FontWeight="Bold"
            Foreground="White" BorderThickness="0"
            Cursor="Hand" Click="BtnAutorHinzufuegen_Click">
        <Button.Style>
            <Style TargetType="Button">
                <Setter Property="Background" Value="#922B21"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#7B241C"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Button.Style>
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="10" Padding="0">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Button.Template>
    </Button>

</Grid>


        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="40,0,40,40">
            <DataGrid x:Name="BuecherDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#ECF0F1"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFBFC"
                      HeadersVisibility="Column">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E74C3C"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Padding" Value="16,12"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"              Binding="{Binding BuchId}"          Width="0.4*"/>
                    <DataGridTextColumn Header="Titel"           Binding="{Binding Titel}"            Width="2.5*"/>
                    <DataGridTextColumn Header="Autor"           Binding="{Binding AutorName}"        Width="1.8*"/>
                    <DataGridTextColumn Header="Kategorie"       Binding="{Binding KategorieName}"    Width="1.2*"/>
                    <DataGridTextColumn Header="Jahr"            Binding="{Binding Erscheinungsjahr}" Width="0.6*"/>
                    <DataGridTextColumn Header="Verlag"          Binding="{Binding Verlag}"           Width="1.2*"/>
                    <DataGridTextColumn Header="Exemplare"       Binding="{Binding AnzahlExemplare}"  Width="0.8*"/>
                    <DataGridTextColumn Header="Verfuegbar"      Binding="{Binding Verfuegbar}"       Width="0.8*"/>

                    <!-- Aktionen -->
                    <DataGridTemplateColumn Header="" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                    <Button Content="&#9998;"
                                            FontSize="16" Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            ToolTip="Buch bearbeiten"
                                            Margin="0,0,8,0"
                                            Tag="{Binding BuchId}"
                                            Click="BtnBuchBearbeiten_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Content="&#128465;"
                                            FontSize="16" Background="Transparent"
                                            BorderThickness="0" Cursor="Hand"
                                            ToolTip="Buch loeschen"
                                            Tag="{Binding BuchId}"
                                            Click="BtnBuchLoeschen_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Page>
