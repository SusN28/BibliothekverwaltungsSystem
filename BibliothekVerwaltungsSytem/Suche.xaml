<Page x:Class="BibliothekVerwaltungsSytem.SuchePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BibliothekVerwaltungsSytem"
      mc:Ignorable="d"
      Title="SuchePage">

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab-Navigation -->
        <Border Grid.Row="0" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="20,0">
                <Button Content="DEIN INVENTAR"
                        Width="180"
                        Height="50"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Background="#ECF0F1"
                        Foreground="#7F8C8D"
                        BorderThickness="0"
                        Margin="0,0,4,0"
                        Cursor="Hand"
                        Click="BtnInventar_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Suche"
                        Width="180"
                        Height="50"
                        FontSize="14"
                        FontWeight="Bold"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnSuche_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                
                <Button Content="BUECHER AUSLEIHEN"
                        Width="200" Height="50" FontSize="14" FontWeight="SemiBold"
                        Background="#ECF0F1" Foreground="#7F8C8D"
                        BorderThickness="0" Margin="4,0,0,0" Cursor="Hand"
                        Click="BtnBuecher_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

        <!-- Premium Searchbox -->
        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#E1E8ED" 
                BorderThickness="0" 
                CornerRadius="12" 
                Margin="40,30,40,40"
                Padding="4">
            <Border.Effect>
                <DropShadowEffect Color="#3498DB20" Direction="270" ShadowDepth="0" BlurRadius="20" Opacity="0.3"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="#3498DB"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            
            <Grid>
                <!-- Input TextBox -->
                <TextBox x:Name="SearchTextBox" 
                         FontSize="18" 
                         FontFamily="Segoe UI"
                         FontWeight="Medium"
                         Foreground="#2C3E50"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="28,22,70,22"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchTextBox_TextChanged"
                         CaretBrush="#3498DB">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Placeholder -->
                <TextBlock x:Name="PlaceholderText"
                           Text="Suche nach Büchern, Autoren oder ISBN..."
                           FontSize="18" 
                           FontFamily="Segoe UI"
                           FontWeight="Medium"
                           Foreground="#95A5A6"
                           Background="Transparent"
                           Padding="28,22,70,22"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsFocused, ElementName=SearchTextBox}" Value="False"/>
                                        <Condition Binding="{Binding Text.Length, ElementName=SearchTextBox}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Such-Icon Button -->
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="48" Height="48"
                        Margin="0,0,20,0"
                        Background="#ECF0F1"
                        CornerRadius="24">
                    <TextBlock Text="🔍" 
                               FontSize="22" 
                               Foreground="#3498DB"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFocused, ElementName=SearchTextBox}" Value="True">
                                    <Setter Property="Background" Value="#3498DB"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="White" BlurRadius="8" ShadowDepth="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </Border>

        <!-- SUCHERGEBNISSE DATAGRID (ersetzt den StackPanel Platzhalter) -->
        <Border Grid.Row="2" Margin="40,0,40,40">
            <DataGrid x:Name="ErgebnisseDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#ECF0F1"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFBFC"
                      HeadersVisibility="Column">
        
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#3498DB"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Padding" Value="16,12"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Autor" Binding="{Binding Autor}" Width="1.5*"/>
                    <DataGridTextColumn Header="Titel" Binding="{Binding Titel}" Width="2.5*"/>
                    <DataGridTextColumn Header="Erscheinungsjahr" Binding="{Binding Erscheinungsjahr}" Width="1*"/>
                    <DataGridTextColumn Header="Ausgeliehen am" Binding="{Binding AusgeliehenAm}" Width="1.2*"/>
                    <DataGridTextColumn Header="Ausgeliehen bis" Binding="{Binding AusgeliehenBis}" Width="1.2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Page>
