<Window x:Class="BibliothekVerwaltungsSytem.AusleihenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buch ausleihen"
        Width="500" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F9FA">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Buch ausleihen"
                       FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock x:Name="TxtBuchInfo"
                       FontSize="13" Foreground="#7F8C8D"
                       TextWrapping="Wrap" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Formular -->
        <StackPanel Grid.Row="1">

            <!-- Ausgeliehen am -->
            <TextBlock Text="Ausgeliehen am" FontSize="13"
                       Foreground="#7F8C8D" Margin="0,0,0,4"/>
            <DatePicker x:Name="DpAusgeliehenAm"
                        FontSize="14" Padding="8,6"
                        Margin="0,0,0,20"
                        BorderBrush="#D5D8DC" BorderThickness="1">
                <DatePicker.Style>
                    <Style TargetType="DatePicker">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DatePicker.Style>
            </DatePicker>

            <!-- Rueckgabe bis -->
            <TextBlock Text="Rueckgabe bis" FontSize="13"
                       Foreground="#7F8C8D" Margin="0,0,0,4"/>
            <DatePicker x:Name="DpRueckgabeBis"
                        FontSize="14" Padding="8,6"
                        Margin="0,0,0,20"
                        BorderBrush="#D5D8DC" BorderThickness="1">
                <DatePicker.Style>
                    <Style TargetType="DatePicker">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DatePicker.Style>
            </DatePicker>

            <!-- Hinweis -->
            <Border Background="#EBF5FB" CornerRadius="6" Padding="12,10">
                <TextBlock FontSize="12" Foreground="#2980B9" TextWrapping="Wrap"
                           Text="Die Ausleihdauer betraegt standardmaessig 28 Tage. Das Rueckgabedatum kann angepasst werden."/>
            </Border>

        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Abbrechen"
                    FontSize="14" FontWeight="SemiBold"
                    Foreground="#7F8C8D" Background="#ECF0F1"
                    BorderThickness="0" Padding="0,12"
                    Cursor="Hand" Click="BtnAbbrechen_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2" Content="Jetzt ausleihen"
                    FontSize="14" FontWeight="Bold"
                    Foreground="White" BorderThickness="0" Padding="0,12"
                    Cursor="Hand" Click="BtnBestaetigen_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#3498DB"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
