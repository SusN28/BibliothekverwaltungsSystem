<Window x:Class="BibliothekVerwaltungsSytem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BibliothekVerwaltungsSytem"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
<Grid Background="#F8F9FA">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320" x:Name="loginPanel">
        <!-- Titel -->
        <TextBlock Text="Login" 
                   FontSize="36" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,50"/>
        <!-- Username Label + Feld -->
        <TextBlock Text="Username" 
                   FontSize="14" 
                   Foreground="#7F8C8D" 
                   Margin="0,0,0,4"/>
        <TextBox Name="txtUsername" 
                 FontSize="16" 
                 Padding="16,12" 
                 Margin="0,0,0,24"
                 Background="White"
                 BorderBrush="#BDC3C7"
                 BorderThickness="1"
                 VerticalContentAlignment="Center"/>
        <!-- Password Label + Feld -->
        <TextBlock Text="Password" 
                   FontSize="14" 
                   Foreground="#7F8C8D" 
                   Margin="0,0,0,4"/>
        <PasswordBox Name="txtPassword" 
                     FontSize="16" 
                     Padding="16,12" 
                     Margin="0,0,0,40"
                     Background="White"
                     BorderBrush="#BDC3C7"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"/>
        <!-- Login Button -->
        <Button Name="btnLogin" 
                Content="Login" 
                Width="140" 
                Height="48" 
                FontSize="16" 
                FontWeight="SemiBold" 
                Background="#3498DB"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Center"
                Margin="0,0,0,20"/>
        <!-- Forgot Password -->
        <TextBlock Text="Forgot Password?" 
                   FontSize="12" 
                   Foreground="#3498DB" 
                   HorizontalAlignment="Center"
                   Cursor="Hand"/>
    </StackPanel>
    <!-- Frame für Pages (unsichtbar bis Login) -->
    <Frame x:Name="mainFrame" 
           NavigationUIVisibility="Hidden" 
           Margin="0" 
           Visibility="Collapsed"/>
</Grid>

</Window>
