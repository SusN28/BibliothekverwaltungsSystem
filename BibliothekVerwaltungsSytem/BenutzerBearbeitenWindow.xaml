<Window x:Class="BibliothekVerwaltungsSytem.BenutzerBearbeitenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User bearbeiten"
        Width="500" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F9FA">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="User bearbeiten"
                       FontSize="24" FontWeight="Bold"
                       Foreground="#2C3E50"/>
            <TextBlock x:Name="TxtSubtitel"
                       FontSize="13" Foreground="#7F8C8D"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Formular -->
        <StackPanel Grid.Row="1">

            <!-- Vorname -->
            <TextBlock Text="Vorname" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtVorname" FontSize="14" Padding="10,8"
                     Margin="0,0,0,14" BorderBrush="#D5D8DC" BorderThickness="1">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E74C3C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Nachname -->
            <TextBlock Text="Nachname" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtNachname" FontSize="14" Padding="10,8"
                     Margin="0,0,0,14" BorderBrush="#D5D8DC" BorderThickness="1">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E74C3C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Username -->
            <TextBlock Text="Benutzername" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtUsername" FontSize="14" Padding="10,8"
                     Margin="0,0,0,14" BorderBrush="#D5D8DC" BorderThickness="1">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E74C3C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- E-Mail -->
            <TextBlock Text="E-Mail" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtEmail" FontSize="14" Padding="10,8"
                     Margin="0,0,0,14" BorderBrush="#D5D8DC" BorderThickness="1">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E74C3C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <!-- Neues Passwort -->
            <TextBlock Text="Neues Passwort (leer lassen = unveraendert)"
                       FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
            <PasswordBox x:Name="TxtPasswort" FontSize="14" Padding="10,8"
                         Margin="0,0,0,14" BorderBrush="#D5D8DC" BorderThickness="1"/>

            <!-- Rolle -->
            <TextBlock Text="Rolle" FontSize="13" Foreground="#7F8C8D" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbRolle" FontSize="14" Padding="10,8"
                      Margin="0,0,0,0" BorderBrush="#D5D8DC" SelectedIndex="0">
                <ComboBoxItem Content="user"/>
                <ComboBoxItem Content="admin"/>
            </ComboBox>

        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Abbrechen -->
            <Button Grid.Column="0"
                    Content="Abbrechen"
                    FontSize="14" FontWeight="SemiBold"
                    Foreground="#7F8C8D" Background="#ECF0F1"
                    BorderThickness="0" Padding="0,12"
                    Cursor="Hand"
                    Click="BtnAbbrechen_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Speichern -->
            <Button Grid.Column="2"
                    Content="Speichern"
                    FontSize="14" FontWeight="Bold"
                    Foreground="White"
                    BorderThickness="0" Padding="0,12"
                    Cursor="Hand"
                    Click="BtnSpeichern_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E74C3C"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Grid>
</Window>
