<Window x:Class="BibliothekVerwaltungsSytem.UserAusleihenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ausleihen verwalten"
        Width="1000" Height="540"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Ausleihen verwalten"
                       FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock x:Name="TxtUserInfo"
                       FontSize="13" Foreground="#7F8C8D" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Statusanzeige -->
        <Border Grid.Row="1" Background="#F2F3F4" CornerRadius="6"
                Padding="16,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Aktive Ausleihen: " FontSize="13" Foreground="#7F8C8D"/>
                <TextBlock x:Name="TxtAnzahlAusleihen"
                           FontSize="13" FontWeight="Bold" Foreground="#E74C3C"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="AusleihenDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#ECF0F1"
                  BorderThickness="0"
                  Background="Transparent"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFBFC"
                  HeadersVisibility="Column">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E74C3C"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="12,10"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Titel"          Binding="{Binding Titel}"          Width="2.5*"/>
                <DataGridTextColumn Header="Autor"          Binding="{Binding Autor}"          Width="1.8*"/>
                <DataGridTextColumn Header="Ausgeliehen am" Binding="{Binding AusgeliehenAm}"  Width="1.2*"/>
                <DataGridTextColumn Header="Rueckgabe bis"  Binding="{Binding RueckgabeBis}"   Width="1.2*"/>

                <!-- Status mit Farbe -->
                <DataGridTemplateColumn Header="Status" Width="1*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FDECEA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IstUeberfaellig}" Value="True">
                                                <Setter Property="Background" Value="#FDECEA"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IstUeberfaellig}" Value="False">
                                                <Setter Property="Background" Value="#EAF4FB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="12" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Aktiv"/>
                                            <Setter Property="Foreground" Value="#2980B9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IstUeberfaellig}" Value="True">
                                                    <Setter Property="Text" Value="Ueberfaellig"/>
                                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Zurueckgeben Button -->
                <DataGridTemplateColumn Header="" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Zurueckgeben"
                                    FontSize="12" FontWeight="SemiBold"
                                    Foreground="White" BorderThickness="0"
                                    Padding="10,5" Cursor="Hand"
                                    Tag="{Binding AusleiheId}"
                                    Click="BtnZurueckgeben_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E74C3C"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#C0392B"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Schliessen Button -->
        <Button Grid.Row="3"
                Content="Schliessen"
                FontSize="14" FontWeight="SemiBold"
                Foreground="#7F8C8D" Background="#ECF0F1"
                BorderThickness="0" Padding="0,12"
                Width="160" HorizontalAlignment="Right"
                Margin="0,20,0,0" Cursor="Hand"
                Click="BtnSchliessen_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</Window>
